# PixDash Environment Configuration
# Copy this file to .env and adjust values as needed.

# Backend bind address
PIXDASH_HOST=0.0.0.0

# Backend port
PIXDASH_PORT=3000

# OpenClaw gateway WebSocket URL
# Non-Docker (local dev): ws://127.0.0.1:18789
# Docker: MUST use host LAN IP, NOT localhost/127.0.0.1
#   Example: ws://192.168.1.200:18789
PIXDASH_GATEWAY_URL=ws://127.0.0.1:18789

# Port (used by Docker Compose; also respected by start.sh)
# Default: 5555 for Docker, 3000 for non-Docker
PIXDASH_PORT=3000

# Enable frontend debug logging (true/false)
PIXDASH_DEBUG=false
